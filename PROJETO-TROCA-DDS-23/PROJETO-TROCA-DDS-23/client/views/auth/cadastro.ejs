<!-- importa o header -->
<%- include('../partials/header')  %>

<main style="height: 300px;">
    <div class="container">
        <!-- ESTILO CARD GERAL -->
        <div class="card"
            style= "padding: 2rem; border: 2px solid var(--cor-borda); box-shadow: 6px 6px 0px var(--cor-borda);
            background-color: var(--cor-fundo)">
            <h2 style="color: var(--cor-destaque); text-align: center; margin-bottom: 5px">
                <i class= "fa-solid fa-user-plus"></i>
                 CRIAR NOVA CONTA</h2>
            <form action="/usuarios/cadastrar" method="post" enctype="multipart/form-data">



                 <!--  Formulário de cadastro -->
                   <div class="row">
                   <div class="col">
                    <fieldset>
                        <legend class="float-none w-auto"> Informações pessoais</legend>
                    </fieldset>
                    <!-- Caixa de nome -->
                     <div class="form-group">
                        <label for="nome">
                            <i class=" fa-solid fa-id-card"></i>Nome Completo:
                        </label>
                        <input type="text" id="nome" name="nome" class="form-control" required>
                     </div>
                     <fieldset class="mt-3">
                        <legend class="float-none w-auto"> Informações de login</legend>
                     </fieldset>

                        <!-- Caixa de email -->
                         <div class="form-group">
                            <label for="email">
                                <i class="fa-solid fa-envelope"></i> E-mail:
                            </label>
                            <input type="email" id="email" name="email" class="form-control" required>
                         </div>

                         <!-- Caixa de perfil -->
                          <div class="form-group">
                            <label for="perfil">
                                <i class="fa-solid fa-users"></i> Qual seu papel?
                            </label>
                            <select id="perfil" name="perfil" class="form-control" required>
                                <option value="">Selecione um perfil</option>
                                <option value="ofertante">Quero oferecer produtos</option>
                                <option value="interessados">Busco produtos</option>
                            </select>
                         </div>

                         <!-- Caixa de foto -->
                          <div class="form-group">
                            <label for="foto">
                                <i class="fa-solid fa-camera"></i>Foto do produto:
                            </label>
                            <input type="file" id="foto" name="foto" class="form-control" accept="image/*" required>
                         </div>
                    </div>
                    <!-- Segunda Coluna -->
                      <div class="col">
                        <!-- Legenda divisão 1 -->
                         <fieldset>
                            <legend class="float-none w-auto text-white">-</legend>
                         </fieldset>

                         <!-- Caixinha de nome -->
                          <div class="form-group">
                            <label for="nome">
                                <i class="fa-solid fa-id-card"></i>Nome Completo:
                            </label>
                            <input type="text" id="nome" name="nome" class="form-control" required>
                         </div>

                          <div class="form-group">
                            <label for="telefone">
                                <i class="fa-solid fa-phone"></i>Telefone:
                            </label>
                            <input type="text" id="telefone" name="telefone" class="form-control" required>
                         </div>

                         <!-- Legenda divisão 2 -->
                          <fieldset class="mt-3">
                            <legend class="float-one w-auto text-white">-</legend>
                          </fieldset>
                         <!-- Caixa de senha -->
                          <div class="form-group">
                            <label for="senha">
                                <i class="fa-solid fa-lock"></i>Senha:
                            </label>
                            <input type="password" id="senha" name="senha" class="form-control" required>
                         </div>
                        <!-- PREVIEW DA IMAGEM -->
                         <div id="preview-bow" class="preview-container max-width:100%" style= "height: 230px ">
                            <img src="..." alt="Foto do usuário" id="preview-img" style="height: 230px; width: auto;">
                         </div>
                   </div>
             </div>

             <!-- Botão de envio -->
              <button type="submit" class="btn btn-secondary" style="width: 100%; margin-top: 15px;">
                 <i class="fa-solid fa-check"></i> Cadastrar
              </button>
         <!-- Opção para ir para página de login -->
          <div style="text-align: center; margin-top: 20px">
            <a href="/login" style="color: var(--cor-texto-principal); font-weight: bold; text-decoration: none"> Já tem conta?</a>
            <span style="color: var(--cor-destaque); text-decoration: underline;"> Faça Login</span>
          </div>
            </form>
        </div>
    </div>
</main>

<!-- importa o footer -->
<%- include('../partials/footer')  %>